<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="6dp"
    app:cardBackgroundColor="@color/surface_dark"
    app:cardCornerRadius="16dp"
    app:strokeWidth="1dp"
    app:strokeColor="@color/card_stroke"
    app:cardElevation="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <!-- Left Accent Bar -->
        <View
            android:id="@+id/sideAccentBar"
            android:layout_width="5dp"
            android:layout_height="match_parent"
            android:background="@color/tanit_amber" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Header Row: Icon + Type + Timestamp -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageView
                    android:id="@+id/iconSeverity"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_warning"
                    android:contentDescription="Alert severity" />

                <TextView
                    android:id="@+id/textViewType"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:textColor="@color/text_primary"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/textViewTimestamp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/text_muted"
                    android:textSize="11sp"
                    android:gravity="center_vertical" />
            </LinearLayout>

            <!-- Severity Badge -->
            <TextView
                android:id="@+id/textViewSeverity"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_status_badge"
                android:paddingHorizontal="10dp"
                android:paddingVertical="3dp"
                android:textSize="10sp"
                android:textStyle="bold" />

            <!-- Message -->
            <TextView
                android:id="@+id/textViewMessage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                android:lineSpacingExtra="3dp" />

            <!-- Room Relocation Info -->
            <LinearLayout
                android:id="@+id/roomRelocInfo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_risk_indicator"
                android:padding="10dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📍 "
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/textViewRelocation"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/tanit_teal"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Action Button -->
            <Button
                android:id="@+id/btnAction"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="12dp"
                android:textColor="@color/tanit_teal"
                app:strokeColor="@color/divider"
                app:cornerRadius="12dp"
                android:text="Voir Planning →"
                android:textSize="13sp"
                android:textAllCaps="false" />

        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>